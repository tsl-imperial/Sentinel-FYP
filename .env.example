# Network Inspector — environment template.
# Copy this file to .env and edit. Both Flask (via python-dotenv) and Next.js
# (via dotenv in next.config.js) read from the top-level .env.

# Earth Engine
EE_PROJECT=sentinel-487715

# Output paths.
# Absolute or relative — relative paths resolve to the repo root, NOT the
# current working directory. Anchored via __file__ in app.py.
NETINSPECT_OUTPUT_DIR=./outputs

# Flask
# Default 5050, NOT 5000 — macOS Control Center / AirPlay Receiver binds 5000.
NETINSPECT_DEV=1
FLASK_RUN_PORT=5050

# Skip Earth Engine init at module load. Default ON in the template so a fresh
# checkout boots cleanly without GEE auth. /api/healthz/ready will return
# "degraded" and the export endpoint will fail at runtime, but the rest of the
# dev stack works. Comment out (or set to 0) once you've run `earthengine authenticate`.
NETINSPECT_SKIP_EE_INIT=1

# Next.js → Flask wiring (used by next.config.js rewrites at dev/build time)
# 127.0.0.1 (not localhost) — avoids IPv6 dual-stack DNS resolution issues on macOS.
FLASK_BACKEND_URL=http://127.0.0.1:5050
# Next.js default port. 3666 mirrors the metis house style.
NEXT_PORT=3666
